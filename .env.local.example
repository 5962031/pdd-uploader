# 复制此文件为 .env.local 并填入你的实际路径
# cp .env.local.example .env.local

# 项目根目录
PDD_ROOT=D:\\pddtest

# Chrome 用户数据目录（保存登录态）
PDD_CHROME_USER_DATA=C:\\Users\\YOUR_USERNAME\\chrome-debug-profile

# Chrome 可执行文件路径（可选，默认值即可）
# PDD_CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe

# CDP 调试端口（可选，默认9222）
# PDD_CDP_PORT=9222
